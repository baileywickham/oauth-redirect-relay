{
  "name": "oauth-redirect-relay",
  "version": "0.2.0",
  "description": "Signed-state OAuth broker pattern: share one registered redirect URI across many dev boxes, safely.",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./express": {
      "types": "./dist/express.d.ts",
      "import": "./dist/express.js"
    }
  },
  "files": ["dist"],
  "keywords": ["oauth", "redirect-uri", "slack", "csrf", "hmac", "broker", "localhost", "dev"],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/baileywickham/oauth-redirect-relay.git"
  },
  "homepage": "https://github.com/baileywickham/oauth-redirect-relay#readme",
  "bugs": {
    "url": "https://github.com/baileywickham/oauth-redirect-relay/issues"
  },
  "scripts": {
    "test": "bun test",
    "build": "bun build src/index.ts src/express.ts --outdir dist --target node && tsc -p tsconfig.build.json",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "bun run typecheck && bun test && bun run build"
  },
  "publishConfig": {
    "access": "public"
  },
  "license": "MIT",
  "devDependencies": {
    "typescript": "^5.6.0",
    "@types/bun": "latest"
  }
}
